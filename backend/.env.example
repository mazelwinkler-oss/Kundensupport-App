# Server
PORT=3001

# HubSpot
HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_access_token

# Weclapp
WECLAPP_TENANT=your_tenant_name
WECLAPP_API_TOKEN=your_weclapp_api_token

# Microsoft 365 / Outlook (optional, fuer E-Mail-Versand via Graph API)
# App registrieren unter: https://portal.azure.com -> App registrations
# Benoetigt werden: Mail.Send Berechtigung (Application)
MICROSOFT_TENANT_ID=your_tenant_id
MICROSOFT_CLIENT_ID=your_client_id
MICROSOFT_CLIENT_SECRET=your_client_secret
MICROSOFT_SENDER_EMAIL=support@direktvomhersteller.de
